    "envSchema": [
      { "name": "ONEMCP_GIT_REPO", "label": "Repository path", "required": true }
    ]
  },
  {
    "id": "github",
    "name": "GitHub",
    "version": "0.6.2",
    "description": "Search code, read issues/PRs, create issues and comments on GitHub via a personal access token.",

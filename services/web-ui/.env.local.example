# This file shows how to configure the API endpoint for development/local testing.
# Copy or rename this to .env.local to use a custom API URL.
#
# For local development (running mcpapiserver locally):
VITE_API_URL=http://localhost:8080

# For production (using Railway deployed service):
# VITE_API_URL=https://mcpapiserver-production.up.railway.app

# The .env.local file is gitignored and will NOT be committed to the repository.
# It's safe to customize this for your local development environment.

{
  "productName": "Mach1 MCP",
  "version": "0.1.2",
  "identifier": "com.mach1.mcp",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mach1 MCP",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBNUU4MDQxMzAwODJDNjgKUldSb0xBZ3dRWUJlbXRnRTRGNWcxYkY2UEErcTdkOW1BWDFsUUw5OWpHWGM2VXZEWDlBNXdkcXQK",
      "endpoints": [
        "https://github.com/SaiAvinashPatoju/1mcp/releases/latest/download/latest.json"
      ],
      "dialog": false
    },
    "shell": {
      "open": true
    }
  }
}

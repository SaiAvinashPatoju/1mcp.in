{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://onemcp.dev/schemas/manifest.schema.json",
  "title": "OneMcpManifest",
  "description": "Source-of-truth manifest for an MCP installable via OneMCP. Go and TS types are generated from this file.",
  "type": "object",
  "required": ["id", "name", "version", "transport", "runtime", "entrypoint"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-_]{1,62}[a-z0-9]$",
      "description": "Stable unique id, used as tool name prefix."
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9.-]+)?$"
    },
    "description": { "type": "string", "maxLength": 2000 },
    "homepage": { "type": "string", "format": "uri" },
    "author": { "type": "string" },
    "license": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" }, "maxItems": 32 },

    "transport": {
      "type": "string",
      "enum": ["stdio", "sse"],
      "description": "MVP supports stdio. sse reserved for Phase 5+."
    },

    "runtime": {
      "type": "string",
      "enum": ["node", "python", "docker", "binary"]
    },

    "entrypoint": {
      "type": "object",
      "description": "How to launch the child MCP. Shape depends on runtime.",
      "oneOf": [
        {
          "required": ["command", "args"],
          "properties": {
            "command": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" } },
            "cwd": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "required": ["image"],
          "properties": {
            "image": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" } },
            "mounts": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["source", "target"],
                "properties": {
                  "source": { "type": "string" },
                  "target": { "type": "string" },
                  "readOnly": { "type": "boolean", "default": true }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },

    "envSchema": {
      "type": "array",
      "description": "User-configurable env vars surfaced in the hub settings UI.",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]*$" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "secret": { "type": "boolean", "default": false },
          "required": { "type": "boolean", "default": false },
          "default": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "network": { "type": "boolean", "default": false },
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read":  { "type": "array", "items": { "type": "string" } },
            "write": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "capabilities": {
      "type": "array",
      "description": "Declared tool/resource capabilities (free-form for now; populated from upstream tools/list at install time).",
      "items": { "type": "string" }
    },

    "embeddingText": {
      "type": "string",
      "description": "Concatenated text fed to the embedder for semantic routing. Generated by hub at install time if absent.",
      "maxLength": 8192
    },

    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "idleShutdownSeconds": { "type": "integer", "minimum": 0, "default": 60 },
        "autostart": { "type": "boolean", "default": false }
      }
    }
  }
}

{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "gopls": {
      "command": ["gopls"],
      "extensions": [".go"]
    },
    "rust-analyzer": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "svelte": {
      "command": ["svelteserver", "--stdio"],
      "extensions": [".svelte"]
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "agent": {
    "go-architect": {
      "mode": "subagent",
      "description": "Specialized in Go 1.22+ for the mach1 router, team-api, and mcpapiserver. Use for building transport layers, auth, and sub-process supervision.",
      "permission": {
        "bash": "allow",
        "read": "allow",
        "edit": "allow"
      }
    },
    "ui-builder": {
      "mode": "subagent",
      "description": "Specialized in SvelteKit and Tauri (Rust) for the Local Hub UI and Team UI.",
      "permission": {
        "bash": "allow",
        "read": "allow",
        "edit": "allow"
      }
    }
  },
  "permission": {
    "bash": "ask",
    "edit": "allow"
  }
}

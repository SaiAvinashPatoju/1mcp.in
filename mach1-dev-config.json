{
  "mcps": [
    {
      "id": "github",
      "name": "GitHub",
      "version": "0.6.2",
      "description": "Search code, read issues/PRs, create issues and comments on GitHub via a personal access token.",
      "tags": ["github", "vcs", "code", "official"],
      "transport": "stdio",
      "runtime": "node",
      "entrypoint": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"]
      },
      "envSchema": [
        {
          "name": "GITHUB_PERSONAL_ACCESS_TOKEN",
          "label": "GitHub Personal Access Token",
          "description": "Fine-grained PAT with the scopes you want the agent to have.",
          "secret": true,
          "required": true,
          "aliases": ["GITHUB_TOKEN", "GH_TOKEN"]
        }
      ],
      "verification": "anthropic-official"
    },
    {
      "id": "brave-search",
      "name": "Brave Search",
      "version": "0.1.0",
      "description": "Web and local search using the Brave Search API.",
      "tags": ["search", "web", "official"],
      "transport": "stdio",
      "runtime": "node",
      "entrypoint": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-brave-search"]
      },
      "envSchema": [
        {
          "name": "BRAVE_API_KEY",
          "label": "Brave Search API key",
          "secret": true,
          "required": true
        }
      ],
      "verification": "anthropic-official"
    },
    {
      "id": "memory",
